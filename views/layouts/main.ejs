<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Система контроля ключей МТС</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/mts-style.css">
</head>
<body>
    <div class="mts-header">
        <div class="container-fluid">
            <a class="navbar-brand" href="/keys/dashboard">
                <img src="https://static.mts.ru/mts_rf/images/logo-eco.svg" alt="МТС" class="mts-logo">
                <div>
                    Система контроля ключей
                    <div class="company-name">ПАО «МТС»</div>
                </div>
            </a>
            <div class="float-end">
                <span class="text-light"><strong><%= user.username %></strong> <span class="badge bg-light text-dark ms-2"><%= user.role %></span></span>
                <form action="/logout" method="post" class="d-inline ms-3">
                    <button type="submit" class="btn btn-outline-light btn-sm">Выйти</button>
                </form>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 mts-sidebar">
                <ul class="sidebar-menu">
                    <li class="<%= activePage === 'dashboard' ? 'active' : '' %>"><a href="/keys/dashboard">Дашборд</a></li>
                    <% if (user.role === 'Администратор') { %>
                        <li class="<%= activePage === 'issue' ? 'active' : '' %>"><a href="/keys/issue">Выдача ключа</a></li>
                        <li class="<%= activePage === 'return' ? 'active' : '' %>"><a href="/keys/return">Возврат ключа</a></li>
                    <% } %>
                    <% if (user.role === 'Администратор') { %>
                        <div class="sidebar-divider"></div>
                        <div class="sidebar-title">Администрирование</div>
                        <li><a href="/stations"><i class="fas fa-tower-cell"></i> Базовые станции</a></li>
                        <li><a href="/keyManagement"><i class="fas fa-key"></i> Управление ключами</a></li>  <!-- ЭТА СТРОКА -->
                        <li><a href="/users"><i class="fas fa-users"></i> Пользователи и роли</a></li>
                    <% } %>
                    <% if (user.role === 'Администратор' || user.role === 'Руководитель') { %>
                        <li class="<%= activePage === 'overdue' ? 'active' : '' %>"><a href="/keys/overdue">Просроченные ключи</a></li>
                        <li class="<%= activePage === 'employee-history' ? 'active' : '' %>"><a href="/keys/employee-history">История сотрудника</a></li>
                    <% } %>
                    <% if (user.role === 'Администратор') { %>
                        <div class="sidebar-divider"></div>
                        <div class="sidebar-title">Администрирование</div>
                        <li class="<%= activePage === 'stations' ? 'active' : '' %>"><a href="/stations">Базовые станции</a></li>
                        <li class="<%= activePage === 'users' ? 'active' : '' %>"><a href="/users">Пользователи и роли</a></li>
                    <% } %>
                    <% if (user.role === 'Администратор' || user.role === 'Аудитор') { %>
                        <li class="<%= activePage === 'audit' ? 'active' : '' %>"><a href="/audit">Журнал аудита</a></li>
                    <% } %>
                </ul>
            </div>
            <div class="col-md-10">
                <div class="mts-content">
                    <%- body %>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>